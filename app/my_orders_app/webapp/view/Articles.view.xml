<mvc:View controllerName="com.test.myordersapp.controller.Articles"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form">
    <Page title="{i18n>lblCAPService}">
        <content>
            <Panel class="sapUiResponsiveMargin"
                width="auto">
                <HBox wrap="Wrap"
                    class="sapUiSmallMarginBottom"
                    alignItems="End">
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="{i18n>lblSearchFor}" />
                        <Input width="200px"
                            placeholder="{i18n>lblArticleCode}"
                            value="{Filters>/CodArticolo}"/>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="{i18n>lblSearchFor}" />
                        <Input width="200px"
                            placeholder="{i18n>lblArticleName}"
                            value="{Filters>/NomeArticolo}"/>
                    </VBox>
                    <HBox>
                        <Button text="{i18n>btnSearch}"
                            type="Emphasized"
                            press=".onSearch"
                            class="sapUiTinyMarginEnd" />
                        <Button text="{i18n>btnReset}"
                            press=".onReset" />
                    </HBox>
                </HBox>
                <Table id="idTableArticles"
                    items="{Articles>/Data}">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="{i18n>lblTable} {i18n>lblArticles}" />
                            <ToolbarSpacer />
                            <Button text="{i18n>lblAddArt}"
                                press=".onOpenCreateDialog"/>
                            <Button text="{i18n>lblTable} {i18n>lblOrders}"
                                press=".onNavToOrders"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column >
                            <Text text="{i18n>lblArticleCode}" />
                        </Column>
                        <Column >
                            <Text text="{i18n>lblArticleName}" />
                        </Column>
                        <Column >
                            <Text text="{i18n>lblImport}" />
                        </Column>
                        <Column >
                            <Text text="{i18n>lblQuantity}" />
                        </Column>
                        <Column width="3rem"
                            hAlign="End">
                        </Column>
                        <Column width="3rem"
                            hAlign="End">
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{Articles>CodArticolo}" />
                                <Text text="{Articles>NomeArticolo}" />
                                <Text text="{Articles>Importo}€" />
                                <Text text="{Articles>QuantitaDisp}" />
                                <Button icon="sap-icon://edit"
                                    press=".onOpenEditDialog" />
                                <Button icon="sap-icon://delete"
                                    type="Reject"
                                    press=".onDeleteArticle" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
                <OverflowToolbar >
                    <ToolbarSpacer />
                    <Button icon="sap-icon://navigation-left-arrow"
                        type="Transparent"
                        press=".onPreviousPage"
                        enabled="{= ${Paging>/skip} > 0 }" />

                    <Button icon="sap-icon://navigation-right-arrow"
                        type="Transparent"
                        press=".onNextPage"
                        enabled="{= ${Articles>/Count} > ${Paging>/skip} + ${Paging>/top} }"/>
                    <ToolbarSpacer />
                </OverflowToolbar>
            </Panel>
        </content>
    </Page>
</mvc:View>